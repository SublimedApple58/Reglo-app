/// Guide di gruppo — a group driving lesson: one instructor + one vehicle + up to
/// `capacity` students. The container exists independently of its participants
/// (open seats); participants are AutoscuolaAppointment rows with type="group_lesson"
/// and groupLessonId set. Does NOT consume a lesson credit; each participant
/// appointment is created as "da pagare" (paymentRequired, paymentStatus="pending").
model AutoscuolaGroupLesson {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId       String    @db.Uuid
  /// "standard" (one shared vehicle, single category — original behaviour) |
  /// "moto" (a fleet of motorcycles, one assigned per participant, mixed
  /// categories, plus ONE shared follow car). See lib/autoscuole/group-moto.ts.
  kind            String    @default("standard")
  instructorId    String?   @db.Uuid
  /// Shared vehicle for kind="standard". Null for kind="moto" (each participant
  /// gets a moto from `fleetVehicles` instead).
  vehicleId       String?   @db.Uuid
  /// Shared follow car ("auto al seguito", category B) for kind="moto". Reserved
  /// at the GROUP level only — never replicated onto participant join rows.
  followVehicleId String?   @db.Uuid
  startsAt        DateTime  @db.Timestamp(6)
  endsAt          DateTime? @db.Timestamp(6)
  capacity        Int       @default(3)
  status          String    @default("scheduled")
  priceAmount     Decimal   @default(0) @db.Decimal(12, 2)
  notes           String?
  createdByUserId String?   @db.Uuid
  createdAt       DateTime  @default(now()) @db.Timestamp(6)
  updatedAt       DateTime  @updatedAt

  company       Company                        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  instructor    AutoscuolaInstructor?          @relation(fields: [instructorId], references: [id], onDelete: SetNull)
  vehicle       AutoscuolaVehicle?             @relation("GroupLessonVehicle", fields: [vehicleId], references: [id], onDelete: SetNull)
  followVehicle AutoscuolaVehicle?             @relation("GroupLessonFollowVehicle", fields: [followVehicleId], references: [id], onDelete: SetNull)
  createdBy     User?                          @relation("GroupLessonCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  appointments  AutoscuolaAppointment[]
  invites       AutoscuolaGroupLessonInvite[]
  fleetVehicles AutoscuolaGroupLessonVehicle[]

  @@index([companyId])
  @@index([companyId, startsAt])
  @@index([instructorId])
  @@index([vehicleId])
  @@index([followVehicleId])
}

/// The motorcycle "fleet" of a kind="moto" group lesson: the explicit set of
/// motos the instructor reserves for the lesson. Defines which students may
/// enrol (a free moto of their category must remain) and bounds capacity. Each
/// enrolled participant is auto-assigned one moto from this set.
model AutoscuolaGroupLessonVehicle {
  groupLessonId String @db.Uuid
  vehicleId     String @db.Uuid

  groupLesson AutoscuolaGroupLesson @relation(fields: [groupLessonId], references: [id], onDelete: Cascade)
  vehicle     AutoscuolaVehicle     @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@id([groupLessonId, vehicleId])
  @@index([vehicleId])
}


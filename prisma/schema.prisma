model AutoscuolaVehicle {
  id                            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId                     String   @db.Uuid
  name                          String
  plate                         String?
  /// active | inactive | maintenance. "maintenance" (fermo temporaneo) is
  /// excluded from matching like inactive, but KEEPS its assignment/pool and
  /// does not cancel existing appointments.
  status                        String   @default("active")
  /// EXCLUSIVE owner of this vehicle (was the 1:1 "fixed" instructor). When set,
  /// the vehicle is reserved to this instructor and hidden from others' pool.
  /// No longer unique: an instructor may own several exclusive vehicles.
  assignedInstructorId          String?  @db.Uuid
  followsInstructorAvailability Boolean  @default(true)
  /// License category this vehicle serves: B | AM | A1 | A2 | A (see lib/autoscuole/license.ts).
  licenseCategory               String   @default("B")
  /// Transmission: manual | automatic.
  transmission                  String   @default("manual")
  createdAt                     DateTime @default(now()) @db.Timestamp(6)
  updatedAt                     DateTime @updatedAt

  company                Company                                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  appointments           AutoscuolaAppointment[]
  groupLessons           AutoscuolaGroupLesson[]                @relation("GroupLessonVehicle")
  groupLessonsAsFollow   AutoscuolaGroupLesson[]                @relation("GroupLessonFollowVehicle")
  groupLessonFleets      AutoscuolaGroupLessonVehicle[]
  assignedInstructor     AutoscuolaInstructor?                  @relation("InstructorExclusiveVehicles", fields: [assignedInstructorId], references: [id], onDelete: SetNull)
  poolMembers            AutoscuolaVehiclePoolMember[]
  preferredByInstructors AutoscuolaInstructorPreferredVehicle[]
  appointmentVehicles    AutoscuolaAppointmentVehicle[]

  @@index([companyId])
  @@index([companyId, assignedInstructorId])
}

/// Shared-pool membership (D2/D3): "instructor X may draw from vehicle V".
/// OPTIONAL — a vehicle with no rows here and no exclusive owner is open to ALL
/// instructors (today's default behavior). An explicit list restricts to it.
model AutoscuolaVehiclePoolMember {
  vehicleId    String @db.Uuid
  instructorId String @db.Uuid

  vehicle    AutoscuolaVehicle    @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  instructor AutoscuolaInstructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@id([vehicleId, instructorId])
  @@index([instructorId])
}

/// Optional tie-break: when an instructor has several compatible vehicles for a
/// category, prefer this one. No row = no preference (fall back to packing score).
model AutoscuolaInstructorPreferredVehicle {
  instructorId    String @db.Uuid
  licenseCategory String // B | BE | C | CE | D | DE | AM | A1 | A2 | A
  vehicleId       String @db.Uuid

  instructor AutoscuolaInstructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  vehicle    AutoscuolaVehicle    @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@id([instructorId, licenseCategory])
  @@index([vehicleId])
}

/// Vehicles reserved by an appointment. Supports multi-vehicle lessons (moto +
/// "auto al seguito"). The `role="primary"` row always mirrors
/// AutoscuolaAppointment.vehicleId (kept as source of truth for existing reads);
/// `role="follow"` is the additional follow car.
model AutoscuolaAppointmentVehicle {
  appointmentId String @db.Uuid
  vehicleId     String @db.Uuid
  role          String @default("primary") // primary | follow

  appointment AutoscuolaAppointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  vehicle     AutoscuolaVehicle     @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@id([appointmentId, vehicleId])
  @@index([vehicleId])
}


generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum IntegrationProvider {
  FATTURE_IN_CLOUD
  STRIPE_CONNECT
}

enum ServiceKey {
  AUTOSCUOLE
}

enum CompanyServiceStatus {
  ACTIVE
  DISABLED
}

enum AutoscuolaRole {
  OWNER
  INSTRUCTOR_OWNER
  INSTRUCTOR
  STUDENT
}

enum AutoscuolaStudentPhase {
  AWAITING
  TEORIA
  PRATICA
  PATENTATO
}

enum QuizSessionMode {
  EXAM
  PRACTICE
  CHAPTER
  REVIEW
  SCHEDA
  SCHEDA_ESAME
}

model User {
  id                                   String                                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                                 String                                 @default("NO_NAME")
  email                                String                                 @unique(map: "user_email_idx")
  emailVerified                        DateTime?                              @db.Timestamp(6)
  image                                String?
  password                             String?
  role                                 String                                 @default("user")
  activeCompanyId                      String?                                @db.Uuid
  address                              Json?                                  @db.Json
  paymentMethod                        String?
  phone                                String?
  createdAt                            DateTime                               @default(now()) @db.Timestamp(6)
  updatedAt                            DateTime                               @updatedAt
  account                              Account[]
  session                              Session[]
  activeCompany                        Company?                               @relation("UserActiveCompany", fields: [activeCompanyId], references: [id], onDelete: SetNull)
  companyMembers                       CompanyMember[]
  companyInvites                       CompanyInvite[]                        @relation("CompanyInviteInvitedBy")
  mobileTokens                         MobileAccessToken[]
  passwordResetCodes                   PasswordResetCode[]
  pushDevices                          MobilePushDevice[]
  autoscuolaInstructors                AutoscuolaInstructor[]
  autoscuolaCases                      AutoscuolaCase[]
  autoscuolaAppointments               AutoscuolaAppointment[]
  autoscuolaBookingRequests            AutoscuolaBookingRequest[]
  autoscuolaWaitlistResponses          AutoscuolaWaitlistResponse[]
  autoscuolaSwapOfferRequests          AutoscuolaSwapOffer[]                  @relation("SwapOfferRequester")
  autoscuolaSwapResponses              AutoscuolaSwapResponse[]               @relation("SwapResponseStudent")
  autoscuolaGroupLessonsCreated        AutoscuolaGroupLesson[]                @relation("GroupLessonCreatedBy")
  autoscuolaGroupLessonInviteResponses AutoscuolaGroupLessonInviteResponse[]
  autoscuolaDocuments                  AutoscuolaDocument[]
  autoscuolaPaymentPlans               AutoscuolaPaymentPlan[]
  autoscuolaPaymentProfiles            AutoscuolaStudentPaymentProfile[]
  autoscuolaLessonCreditBalances       AutoscuolaStudentLessonCreditBalance[]
  autoscuolaLessonCreditLedgerStudent  AutoscuolaStudentLessonCreditLedger[]  @relation("AutoscuolaCreditLedgerStudent")
  autoscuolaLessonCreditLedgerActor    AutoscuolaStudentLessonCreditLedger[]  @relation("AutoscuolaCreditLedgerActor")
  autoscuolaAppointmentPayments        AutoscuolaAppointmentPayment[]
  autoscuolaMessageLogs                AutoscuolaMessageLog[]
  autoscuolaWeeklyAbsences             AutoscuolaStudentWeeklyAbsence[]
  autoscuolaVoiceCallsStudent          AutoscuolaVoiceCall[]                  @relation("AutoscuolaVoiceCallStudent")
  autoscuolaVoiceCallbackTasksStudent  AutoscuolaVoiceCallbackTask[]          @relation("AutoscuolaVoiceCallbackStudent")
  autoscuolaVoiceCallbackTasksAssignee AutoscuolaVoiceCallbackTask[]          @relation("AutoscuolaVoiceCallbackAssignee")
  quizSessions                         QuizSession[]
  autoscuolaLocationsCreated           AutoscuolaLocation[]                   @relation("AutoscuolaLocationCreatedBy")
  supportMessages                      SupportMessage[]
  productFeedback                      ProductFeedback[]

  @@index([phone])
}

model Account {
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @id
  userId       String   @db.Uuid
  expires      DateTime @db.Timestamp(6)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model MobileAccessToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @db.Uuid
  companyId  String?   @db.Uuid
  tokenHash  String    @unique
  createdAt  DateTime  @default(now()) @db.Timestamp(6)
  lastUsedAt DateTime? @db.Timestamp(6)
  expiresAt  DateTime  @db.Timestamp(6)

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([companyId])
  @@index([expiresAt])
}

model PasswordResetCode {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @db.Uuid
  codeHash   String
  attempts   Int       @default(0)
  expiresAt  DateTime  @db.Timestamp(6)
  consumedAt DateTime? @db.Timestamp(6)
  createdAt  DateTime  @default(now()) @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model MobilePushDevice {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @db.Uuid
  companyId  String?   @db.Uuid
  token      String    @unique
  platform   String
  deviceId   String?
  appVersion String?
  createdAt  DateTime  @default(now()) @db.Timestamp(6)
  updatedAt  DateTime  @updatedAt
  lastSeenAt DateTime  @default(now()) @db.Timestamp(6)
  disabledAt DateTime? @db.Timestamp(6)

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([companyId])
  @@index([disabledAt])
}

model Company {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  logoKey    String?
  createdAt  DateTime @default(now()) @db.Timestamp(6)
  updatedAt  DateTime @updatedAt
  inviteCode String?  @unique

  members                              CompanyMember[]
  activeUsers                          User[]                                 @relation("UserActiveCompany")
  invites                              CompanyInvite[]
  integrationConnections               IntegrationConnection[]
  autoscuolaCases                      AutoscuolaCase[]
  autoscuolaAppointments               AutoscuolaAppointment[]
  autoscuolaInstructors                AutoscuolaInstructor[]
  autoscuolaInstructorBlocks           AutoscuolaInstructorBlock[]
  autoscuolaVehicles                   AutoscuolaVehicle[]
  autoscuolaAvailabilitySlots          AutoscuolaAvailabilitySlot[]
  autoscuolaWeeklyAvailabilities       AutoscuolaWeeklyAvailability[]
  autoscuolaDailyAvailabilityOverrides AutoscuolaDailyAvailabilityOverride[]
  autoscuolaBookingRequests            AutoscuolaBookingRequest[]
  autoscuolaWaitlistOffers             AutoscuolaWaitlistOffer[]
  autoscuolaSwapOffers                 AutoscuolaSwapOffer[]
  autoscuolaGroupLessons               AutoscuolaGroupLesson[]
  autoscuolaGroupLessonInvites         AutoscuolaGroupLessonInvite[]
  autoscuolaDocuments                  AutoscuolaDocument[]
  autoscuolaPaymentPlans               AutoscuolaPaymentPlan[]
  autoscuolaPaymentProfiles            AutoscuolaStudentPaymentProfile[]
  autoscuolaLessonCreditBalances       AutoscuolaStudentLessonCreditBalance[]
  autoscuolaLessonCreditLedger         AutoscuolaStudentLessonCreditLedger[]
  autoscuolaAppointmentPayments        AutoscuolaAppointmentPayment[]
  autoscuolaMessageTemplates           AutoscuolaMessageTemplate[]
  autoscuolaMessageRules               AutoscuolaMessageRule[]
  autoscuolaMessageLogs                AutoscuolaMessageLog[]
  autoscuolaWeeklyAbsences             AutoscuolaStudentWeeklyAbsence[]
  autoscuolaVoiceLines                 AutoscuolaVoiceLine[]
  autoscuolaVoiceCalls                 AutoscuolaVoiceCall[]
  autoscuolaVoiceCallbackTasks         AutoscuolaVoiceCallbackTask[]
  autoscuolaVoiceKnowledgeChunks       AutoscuolaVoiceKnowledgeChunk[]
  services                             CompanyService[]
  mobileTokens                         MobileAccessToken[]
  pushDevices                          MobilePushDevice[]
  autoscuolaHolidays                   AutoscuolaHoliday[]
  autoscuolaInstructorPublishedWeeks   AutoscuolaInstructorPublishedWeek[]
  quizSessions                         QuizSession[]
  autoscuolaLocations                  AutoscuolaLocation[]
  supportThread                        SupportThread?
  productFeedback                      ProductFeedback[]
}

model CompanyService {
  id         String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId  String               @db.Uuid
  serviceKey ServiceKey
  status     CompanyServiceStatus @default(ACTIVE)
  limits     Json?                @db.Json
  createdAt  DateTime             @default(now()) @db.Timestamp(6)
  updatedAt  DateTime             @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, serviceKey])
  @@index([companyId])
  @@index([serviceKey])
}

model CompanyMember {
  companyId                String                 @db.Uuid
  userId                   String                 @db.Uuid
  role                     String                 @default("member")
  autoscuolaRole           AutoscuolaRole         @default(STUDENT)
  studentPhase             AutoscuolaStudentPhase @default(PRATICA)
  /// When the student was first granted a quiz license seat by the school owner.
  /// Null = never granted. Once set, the seat is "burnt" for life on this student
  /// (nominal license, non-reassignable). Drives the quiz tab visibility in mobile.
  quizSeatGrantedAt        DateTime?
  /// When the student's phase was explicitly classified by the school owner
  /// (i.e. not the default migration value). Null = still "default migration"
  /// (drives the yellow "Conferma fase" badge in the titolare drawer).
  phaseClassifiedAt        DateTime?
  bookingBlocked           Boolean                @default(false)
  weeklyBookingLimitExempt Boolean                @default(false)
  examPriorityOverride     Boolean?
  assignedInstructorId     String?                @db.Uuid
  /// License path the student is pursuing (PRATICA phase). Part of the Vehicles
  /// module: drives category-aware slot matching only when vehiclesEnabled.
  /// Null on non-student members. Values: B | AM | A1 | A2 | A (see lib/autoscuole/license.ts).
  licenseCategory          String?
  /// Transmission of the pursued license: manual | automatic.
  transmission             String?
  /// Whether this student may participate in group driving lessons (Guide di gruppo).
  /// Opt-in, default false. Only meaningful when limits.groupLessonsEnabled is on.
  groupLessonsOptIn        Boolean                @default(false)
  createdAt                DateTime               @default(now()) @db.Timestamp(6)
  updatedAt                DateTime               @updatedAt

  company            Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user               User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedInstructor AutoscuolaInstructor? @relation("InstructorAssignedStudents", fields: [assignedInstructorId], references: [id], onDelete: SetNull)

  @@id([companyId, userId])
  @@index([userId])
  @@index([assignedInstructorId])
  @@index([companyId, studentPhase])
  @@index([companyId, quizSeatGrantedAt])
  @@index([companyId, autoscuolaRole])
}

model CompanyInvite {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId      String   @db.Uuid
  email          String
  role           String   @default("member")
  autoscuolaRole String?
  token          String   @unique
  status         String   @default("pending")
  platform       String?
  expiresAt      DateTime @db.Timestamp(6)
  invitedById    String?  @db.Uuid
  createdAt      DateTime @default(now()) @db.Timestamp(6)
  updatedAt      DateTime @updatedAt

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invitedBy User?   @relation("CompanyInviteInvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([email])
}

model IntegrationConnection {
  id                     String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId              String              @db.Uuid
  provider               IntegrationProvider
  status                 String              @default("connected")
  externalAccountId      String?
  displayName            String?
  scope                  String?
  accessTokenCiphertext  String?
  accessTokenIv          String?
  accessTokenTag         String?
  refreshTokenCiphertext String?
  refreshTokenIv         String?
  refreshTokenTag        String?
  expiresAt              DateTime?
  metadata               Json?
  createdAt              DateTime            @default(now()) @db.Timestamp(6)
  updatedAt              DateTime            @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, provider])
  @@index([provider])
}

model AutoscuolaCase {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId          String    @db.Uuid
  studentId          String    @db.Uuid
  category           String?
  status             String    @default("iscritto")
  theoryExamAt       DateTime? @db.Timestamp(6)
  drivingExamAt      DateTime? @db.Timestamp(6)
  pinkSheetExpiresAt DateTime? @db.Timestamp(6)
  medicalExpiresAt   DateTime? @db.Timestamp(6)
  createdAt          DateTime  @default(now()) @db.Timestamp(6)
  updatedAt          DateTime  @updatedAt

  company      Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  student      User                    @relation(fields: [studentId], references: [id], onDelete: Restrict)
  appointments AutoscuolaAppointment[]
  paymentPlans AutoscuolaPaymentPlan[]

  @@index([companyId])
  @@index([studentId])
  @@index([status])
  @@index([companyId, pinkSheetExpiresAt])
  @@index([companyId, medicalExpiresAt])
}

model AutoscuolaAppointment {
  id                           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId                    String    @db.Uuid
  studentId                    String    @db.Uuid
  caseId                       String?   @db.Uuid
  slotId                       String?   @db.Uuid
  type                         String
  types                        String[]  @default([])
  rating                       Int?
  startsAt                     DateTime  @db.Timestamp(6)
  endsAt                       DateTime? @db.Timestamp(6)
  status                       String    @default("scheduled")
  instructorId                 String?   @db.Uuid
  vehicleId                    String?   @db.Uuid
  notes                        String?
  paymentRequired              Boolean   @default(false)
  paymentStatus                String    @default("not_required")
  priceAmount                  Decimal   @default(0) @db.Decimal(12, 2)
  penaltyAmount                Decimal   @default(0) @db.Decimal(12, 2)
  penaltyCutoffAt              DateTime? @db.Timestamp(6)
  paidAmount                   Decimal   @default(0) @db.Decimal(12, 2)
  cancelledAt                  DateTime? @db.Timestamp(6)
  cancelledByUserId            String?   @db.Uuid
  cancellationKind             String?
  cancellationReason           String?
  replacedByAppointmentId      String?   @db.Uuid
  invoiceId                    String?
  invoiceStatus                String?
  creditApplied                Boolean   @default(false)
  creditRefundedAt             DateTime? @db.Timestamp(6)
  availabilityOverrideApproved Boolean   @default(false)
  manualPaymentStatus          String?
  lateCancellationAction       String?
  rescheduledAt                DateTime? @db.Timestamp(6)
  rescheduledFromStartsAt      DateTime? @db.Timestamp(6)
  locationId                   String?   @db.Uuid
  /// When set, this appointment is one participant seat of a group lesson
  /// (Guide di gruppo). type = "group_lesson". Null for normal lessons/exams.
  groupLessonId                String?   @db.Uuid
  /// How this appointment was created — the CHANNEL/category, not a specific user:
  /// student_self | swap | slot_fill | staff_instructor | staff_owner | voice |
  /// group_lesson | exam. Null on legacy rows created before this field existed.
  /// See lib/autoscuole/booking-source.ts. Used for ops/reporting (e.g. "who
  /// booked the over-limit guide"). slot_fill/group_lesson/exam intentionally
  /// bypass the weekly booking limit.
  bookingSource                String?
  createdAt                    DateTime  @default(now()) @db.Timestamp(6)
  updatedAt                    DateTime  @updatedAt

  company               Company                               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  student               User                                  @relation(fields: [studentId], references: [id], onDelete: Restrict)
  case                  AutoscuolaCase?                       @relation(fields: [caseId], references: [id], onDelete: SetNull)
  slot                  AutoscuolaAvailabilitySlot?           @relation(fields: [slotId], references: [id], onDelete: SetNull)
  instructor            AutoscuolaInstructor?                 @relation(fields: [instructorId], references: [id], onDelete: SetNull)
  vehicle               AutoscuolaVehicle?                    @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  location              AutoscuolaLocation?                   @relation(fields: [locationId], references: [id], onDelete: SetNull)
  groupLesson           AutoscuolaGroupLesson?                @relation(fields: [groupLessonId], references: [id], onDelete: Cascade)
  replacedByAppointment AutoscuolaAppointment?                @relation("AutoscuolaAppointmentReplacement", fields: [replacedByAppointmentId], references: [id], onDelete: SetNull)
  replacedAppointments  AutoscuolaAppointment[]               @relation("AutoscuolaAppointmentReplacement")
  payments              AutoscuolaAppointmentPayment[]
  creditLedger          AutoscuolaStudentLessonCreditLedger[]
  messageLogs           AutoscuolaMessageLog[]
  voiceCalls            AutoscuolaVoiceCall[]
  swapOffers            AutoscuolaSwapOffer[]
  appointmentVehicles   AutoscuolaAppointmentVehicle[]

  @@index([companyId])
  @@index([studentId])
  @@index([startsAt])
  @@index([instructorId])
  @@index([vehicleId])
  @@index([slotId])
  @@index([paymentRequired, paymentStatus])
  @@index([penaltyCutoffAt])
  @@index([companyId, startsAt])
  @@index([companyId, status, startsAt])
  @@index([companyId, instructorId, startsAt])
  @@index([companyId, studentId, startsAt])
  @@index([companyId, paymentRequired, startsAt])
  @@index([companyId, studentId, creditApplied])
  @@index([companyId, studentId, paymentRequired, paymentStatus])
  @@index([replacedByAppointmentId])
  @@index([companyId, cancellationKind, startsAt])
  @@index([locationId])
  @@index([groupLessonId])
}

model AutoscuolaLocation {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId       String    @db.Uuid
  createdByUserId String?   @db.Uuid
  name            String
  address         String?
  latitude        Decimal?  @db.Decimal(10, 7)
  longitude       Decimal?  @db.Decimal(10, 7)
  placeId         String?
  isDefault       Boolean   @default(false)
  isPrecise       Boolean   @default(false)
  archivedAt      DateTime? @db.Timestamp(6)
  createdAt       DateTime  @default(now()) @db.Timestamp(6)
  updatedAt       DateTime  @updatedAt

  company       Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdByUser User?                   @relation("AutoscuolaLocationCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  appointments  AutoscuolaAppointment[]

  @@index([companyId])
  @@index([companyId, archivedAt])
}

model AutoscuolaVoiceLine {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId      String   @db.Uuid
  displayNumber  String
  twilioNumber   String
  twilioPhoneSid String
  status         String   @default("ready")
  routingMode    String   @default("twilio")
  createdAt      DateTime @default(now()) @db.Timestamp(6)
  updatedAt      DateTime @updatedAt

  company Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  calls   AutoscuolaVoiceCall[]

  @@unique([twilioPhoneSid])
  @@index([companyId])
}

model AutoscuolaVoiceCall {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId      String    @db.Uuid
  lineId         String    @db.Uuid
  twilioCallSid  String    @unique
  fromNumber     String
  toNumber       String
  status         String    @default("received")
  studentId      String?   @db.Uuid
  appointmentId  String?   @db.Uuid
  startedAt      DateTime  @default(now()) @db.Timestamp(6)
  endedAt        DateTime? @db.Timestamp(6)
  durationSec    Int?
  outcome        String?
  summary        String?
  recordingSid   String?
  recordingUrl   String?
  transcriptText String?
  needsCallback  Boolean   @default(false)
  createdAt      DateTime  @default(now()) @db.Timestamp(6)
  updatedAt      DateTime  @updatedAt

  company       Company                       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  line          AutoscuolaVoiceLine           @relation(fields: [lineId], references: [id], onDelete: Cascade)
  student       User?                         @relation("AutoscuolaVoiceCallStudent", fields: [studentId], references: [id], onDelete: SetNull)
  appointment   AutoscuolaAppointment?        @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  turns         AutoscuolaVoiceCallTurn[]
  callbackTasks AutoscuolaVoiceCallbackTask[]

  @@index([companyId, status, startedAt])
  @@index([lineId])
  @@index([studentId])
  @@index([appointmentId])
}

model AutoscuolaVoiceCallTurn {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  callId     String   @db.Uuid
  speaker    String
  text       String
  confidence Float?
  createdAt  DateTime @default(now()) @db.Timestamp(6)

  call AutoscuolaVoiceCall @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@index([callId, createdAt])
}

model AutoscuolaVoiceCallbackTask {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId        String    @db.Uuid
  callId           String    @db.Uuid
  studentId        String?   @db.Uuid
  phoneNumber      String
  reason           String
  status           String    @default("pending")
  assignedToUserId String?   @db.Uuid
  nextAttemptAt    DateTime? @db.Timestamp(6)
  attemptCount     Int       @default(0)
  createdAt        DateTime  @default(now()) @db.Timestamp(6)
  updatedAt        DateTime  @updatedAt

  company  Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  call     AutoscuolaVoiceCall @relation(fields: [callId], references: [id], onDelete: Cascade)
  student  User?               @relation("AutoscuolaVoiceCallbackStudent", fields: [studentId], references: [id], onDelete: SetNull)
  assignee User?               @relation("AutoscuolaVoiceCallbackAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)

  @@index([companyId, status, nextAttemptAt])
  @@index([studentId])
}

model AutoscuolaVoiceKnowledgeChunk {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  scope     String
  companyId String?  @db.Uuid
  title     String
  content   String
  tags      String[]
  language  String   @default("it-IT")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt

  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([scope, companyId, language, active])
}

model AutoscuolaInstructor {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId      String   @db.Uuid
  userId         String?  @db.Uuid
  name           String
  phone          String?
  /// Owner-picked display color (hex, e.g. "#0EA5E9") for avatars/agenda.
  /// Null = automatic (positional palette fallback on the clients).
  color          String?
  status         String   @default("active")
  autonomousMode Boolean  @default(false)
  settings       Json?    @db.Json
  /// Per-instructor invite code (6 chars). A student registering with it joins
  /// the school AND is assigned to this instructor — accepted only while the
  /// instructor is active + autonomousMode. Shares the signup field with
  /// Company.inviteCode (company-first lookup; cross-table uniqueness enforced
  /// at generation time).
  inviteCode     String?  @unique
  createdAt      DateTime @default(now()) @db.Timestamp(6)
  updatedAt      DateTime @updatedAt

  company                Company                                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user                   User?                                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  appointments           AutoscuolaAppointment[]
  blocks                 AutoscuolaInstructorBlock[]
  assignedStudents       CompanyMember[]                        @relation("InstructorAssignedStudents")
  weeklyAbsences         AutoscuolaStudentWeeklyAbsence[]
  publishedWeeks         AutoscuolaInstructorPublishedWeek[]
  // Vehicles EXCLUSIVELY owned by this instructor (1:N now; no @@unique). A
  // vehicle exclusive to an instructor is hidden from every other instructor's
  // pool. An instructor may own several (e.g. their car + their moto).
  exclusiveVehicles      AutoscuolaVehicle[]                    @relation("InstructorExclusiveVehicles")
  // Shared-pool memberships: vehicles this instructor may draw from (N:N).
  vehiclePoolMemberships AutoscuolaVehiclePoolMember[]
  // Preferred vehicle per license category (tie-break when several compatible).
  preferredVehicles      AutoscuolaInstructorPreferredVehicle[]

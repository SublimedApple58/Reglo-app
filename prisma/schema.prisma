  company    Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  student    User                 @relation(fields: [studentId], references: [id], onDelete: Cascade)
  instructor AutoscuolaInstructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@unique([companyId, studentId, weekStart])
  @@index([companyId, instructorId, weekStart])
}

model QuizChapter {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chapterNumber Int      @unique
  description   String
  createdAt     DateTime @default(now()) @db.Timestamp(6)

  questions QuizQuestion[]
  sessions  QuizSession[]
  schede    QuizScheda[]
}

model QuizScheda {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type           String   @default("CHAPTER")
  chapterId      String?  @db.Uuid
  schedaNumber   Int
  questionIds    String[] @db.Uuid
  totalQuestions Int
  createdAt      DateTime @default(now()) @db.Timestamp(6)

  chapter  QuizChapter?  @relation(fields: [chapterId], references: [id])
  sessions QuizSession[]

  @@unique([type, chapterId, schedaNumber])
  @@index([chapterId])
  @@index([type])
}

model QuizHint {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  externalId      Int      @unique
  title           String
  descriptionHtml String   @db.Text
  createdAt       DateTime @default(now()) @db.Timestamp(6)

  questions QuizQuestion[]
}

model QuizQuestion {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  externalId    Int      @unique
  argumentId    String
  chapterId     String   @db.Uuid
  hintId        String?  @db.Uuid
  imageKey      String?
  questionText  String
  correctAnswer Boolean
  createdAt     DateTime @default(now()) @db.Timestamp(6)

  chapter QuizChapter               @relation(fields: [chapterId], references: [id])
  hint    QuizHint?                 @relation(fields: [hintId], references: [id])
  answers QuizAnswer[]
  stats   QuizStudentQuestionStat[]

  @@index([chapterId])
  @@index([hintId])
  @@index([argumentId])
}

model QuizSession {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId      String          @db.Uuid
  studentId      String          @db.Uuid
  mode           QuizSessionMode
  chapterId      String?         @db.Uuid
  schedaId       String?         @db.Uuid
  questionIds    String[]        @db.Uuid
  status         String          @default("in_progress")
  totalQuestions Int
  correctCount   Int             @default(0)
  wrongCount     Int             @default(0)
  passed         Boolean?
  startedAt      DateTime        @default(now()) @db.Timestamp(6)
  completedAt    DateTime?       @db.Timestamp(6)
  timeLimitSec   Int?
  createdAt      DateTime        @default(now()) @db.Timestamp(6)
  updatedAt      DateTime        @updatedAt

  company Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  student User         @relation(fields: [studentId], references: [id])
  chapter QuizChapter? @relation(fields: [chapterId], references: [id])
  scheda  QuizScheda?  @relation(fields: [schedaId], references: [id])
  answers QuizAnswer[]

  @@index([companyId, studentId])
  @@index([companyId, studentId, mode])
  @@index([companyId, studentId, schedaId])
  @@index([studentId, status])
}

model QuizAnswer {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId     String   @db.Uuid
  questionId    String   @db.Uuid
  studentAnswer Boolean
  isCorrect     Boolean
  answeredAt    DateTime @default(now()) @db.Timestamp(6)

  session  QuizSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question QuizQuestion @relation(fields: [questionId], references: [id])

  @@index([sessionId])
  @@index([questionId])
}

model QuizStudentQuestionStat {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId      String   @db.Uuid
  studentId      String   @db.Uuid
  questionId     String   @db.Uuid
  timesAnswered  Int      @default(0)
  timesCorrect   Int      @default(0)
  lastAnsweredAt DateTime @db.Timestamp(6)

  question QuizQuestion @relation(fields: [questionId], references: [id])

  @@unique([companyId, studentId, questionId])
  @@index([companyId, studentId])
}

// ── Reglo Aula ────────────────────────────────────────────────────────────────
// Lezioni di teoria in aula. Unica tabella: solo metadati + puntatore al pacchetto
// slide (.rppt) su R2. Il contenuto slide vive su R2, il quiz live tutto in Redis
// (effimero, 0 storico). Vedi docs/features/reglo-aula.md.
// companyId null = template globale Reglo; valorizzato = fork per autoscuola.
// chapterId/sourceLessonId sono FK logiche (scalari, nessuna relation Prisma) per
// mantenere la migrazione minima e non toccare QuizChapter.
model AulaLesson {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId      String?  @db.Uuid
  chapterId      String?  @db.Uuid
  title          String
  description    String?
  order          Int      @default(0)
  isTemplate     Boolean  @default(false)
  sourceLessonId String?  @db.Uuid
  packageR2Key   String
  createdAt      DateTime @default(now()) @db.Timestamp(6)
  updatedAt      DateTime @updatedAt

  @@index([companyId])
  @@index([chapterId])
  @@index([isTemplate])
}

// ── Centro assistenza + feedback ─────────────────────────────────────────────
// Chat di supporto tra l'autoscuola (web app) e il team Reglo (backoffice):
// un thread per company, messaggi bidirezionali con contatori non-letti per
// lato. ProductFeedback = valutazioni dalla dialog "Lascia un feedback".
// Vedi docs/features/support-center.md.
model SupportThread {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId          String   @unique @db.Uuid
  status             String   @default("open")
  lastMessageAt      DateTime @default(now()) @db.Timestamp(6)
  lastMessagePreview String?
  unreadForAdmin     Int      @default(0)
  unreadForCompany   Int      @default(0)
  createdAt          DateTime @default(now()) @db.Timestamp(6)
  updatedAt          DateTime @updatedAt

  company  Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  messages SupportMessage[]

  @@index([lastMessageAt])
}

model SupportMessage {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  threadId     String   @db.Uuid
  /// "company" (autoscuola) | "reglo" (team, dal backoffice)
  sender       String
  senderUserId String?  @db.Uuid
  /// Snapshot del nome al momento dell'invio (sopravvive alla cancellazione utente)
  senderName   String?
  body         String
  createdAt    DateTime @default(now()) @db.Timestamp(6)

  thread     SupportThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderUser User?         @relation(fields: [senderUserId], references: [id], onDelete: SetNull)

  @@index([threadId, createdAt])
}

model ProductFeedback {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String?  @db.Uuid
  userId    String?  @db.Uuid
  /// Snapshot del nome al momento dell'invio
  userName  String?
  rating    Int
  tags      String[] @default([])
  message   String?
  createdAt DateTime @default(now()) @db.Timestamp(6)

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([createdAt])
}

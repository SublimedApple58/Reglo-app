generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum IntegrationProvider {
  FATTURE_IN_CLOUD
  STRIPE_CONNECT
}

enum ServiceKey {
  AUTOSCUOLE
}

enum CompanyServiceStatus {
  ACTIVE
  DISABLED
}

enum AutoscuolaRole {
  OWNER
  INSTRUCTOR
  STUDENT
}

model User {
  id                                   String                                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                                 String                                 @default("NO_NAME")
  email                                String                                 @unique(map: "user_email_idx")
  emailVerified                        DateTime?                              @db.Timestamp(6)
  image                                String?
  password                             String?
  role                                 String                                 @default("user")
  activeCompanyId                      String?                                @db.Uuid
  address                              Json?                                  @db.Json
  paymentMethod                        String?
  phone                                String?
  createdAt                            DateTime                               @default(now()) @db.Timestamp(6)
  updatedAt                            DateTime                               @updatedAt
  account                              Account[]
  session                              Session[]
  activeCompany                        Company?                               @relation("UserActiveCompany", fields: [activeCompanyId], references: [id], onDelete: SetNull)
  companyMembers                       CompanyMember[]
  companyInvites                       CompanyInvite[]                        @relation("CompanyInviteInvitedBy")
  mobileTokens                         MobileAccessToken[]
  pushDevices                          MobilePushDevice[]
  autoscuolaInstructors                AutoscuolaInstructor[]
  autoscuolaCases                      AutoscuolaCase[]
  autoscuolaAppointments               AutoscuolaAppointment[]
  autoscuolaBookingRequests            AutoscuolaBookingRequest[]
  autoscuolaWaitlistResponses          AutoscuolaWaitlistResponse[]
  autoscuolaDocuments                  AutoscuolaDocument[]
  autoscuolaPaymentPlans               AutoscuolaPaymentPlan[]
  autoscuolaPaymentProfiles            AutoscuolaStudentPaymentProfile[]
  autoscuolaLessonCreditBalances       AutoscuolaStudentLessonCreditBalance[]
  autoscuolaLessonCreditLedgerStudent  AutoscuolaStudentLessonCreditLedger[]  @relation("AutoscuolaCreditLedgerStudent")
  autoscuolaLessonCreditLedgerActor    AutoscuolaStudentLessonCreditLedger[]  @relation("AutoscuolaCreditLedgerActor")
  autoscuolaAppointmentPayments        AutoscuolaAppointmentPayment[]
  autoscuolaRepositionTasksStudent     AutoscuolaAppointmentRepositionTask[]  @relation("AutoscuolaRepositionTaskStudent")
  autoscuolaRepositionTasksActor       AutoscuolaAppointmentRepositionTask[]  @relation("AutoscuolaRepositionTaskActor")
  autoscuolaMessageLogs                AutoscuolaMessageLog[]
  autoscuolaVoiceCallsStudent          AutoscuolaVoiceCall[]                  @relation("AutoscuolaVoiceCallStudent")
  autoscuolaVoiceCallbackTasksStudent  AutoscuolaVoiceCallbackTask[]          @relation("AutoscuolaVoiceCallbackStudent")
  autoscuolaVoiceCallbackTasksAssignee AutoscuolaVoiceCallbackTask[]          @relation("AutoscuolaVoiceCallbackAssignee")

  @@index([phone])
}

model Account {
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @id
  userId       String   @db.Uuid
  expires      DateTime @db.Timestamp(6)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model MobileAccessToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @db.Uuid
  companyId  String?   @db.Uuid
  tokenHash  String    @unique
  createdAt  DateTime  @default(now()) @db.Timestamp(6)
  lastUsedAt DateTime? @db.Timestamp(6)
  expiresAt  DateTime  @db.Timestamp(6)

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([companyId])
  @@index([expiresAt])
}

model MobilePushDevice {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @db.Uuid
  companyId  String?   @db.Uuid
  token      String    @unique
  platform   String
  deviceId   String?
  appVersion String?
  createdAt  DateTime  @default(now()) @db.Timestamp(6)
  updatedAt  DateTime  @updatedAt
  lastSeenAt DateTime  @default(now()) @db.Timestamp(6)
  disabledAt DateTime? @db.Timestamp(6)

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([companyId])
  @@index([disabledAt])
}

model Company {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  logoKey   String?
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt   DateTime @updatedAt
  inviteCode  String?  @unique

  members                        CompanyMember[]
  activeUsers                    User[]                                 @relation("UserActiveCompany")
  invites                        CompanyInvite[]
  integrationConnections         IntegrationConnection[]
  autoscuolaCases                AutoscuolaCase[]
  autoscuolaAppointments         AutoscuolaAppointment[]
  autoscuolaInstructors          AutoscuolaInstructor[]
  autoscuolaInstructorBlocks     AutoscuolaInstructorBlock[]
  autoscuolaVehicles             AutoscuolaVehicle[]
  autoscuolaAvailabilitySlots    AutoscuolaAvailabilitySlot[]
  autoscuolaWeeklyAvailabilities         AutoscuolaWeeklyAvailability[]
  autoscuolaDailyAvailabilityOverrides  AutoscuolaDailyAvailabilityOverride[]
  autoscuolaBookingRequests      AutoscuolaBookingRequest[]
  autoscuolaWaitlistOffers       AutoscuolaWaitlistOffer[]
  autoscuolaDocuments            AutoscuolaDocument[]
  autoscuolaPaymentPlans         AutoscuolaPaymentPlan[]
  autoscuolaPaymentProfiles      AutoscuolaStudentPaymentProfile[]
  autoscuolaLessonCreditBalances AutoscuolaStudentLessonCreditBalance[]
  autoscuolaLessonCreditLedger   AutoscuolaStudentLessonCreditLedger[]
  autoscuolaAppointmentPayments  AutoscuolaAppointmentPayment[]
  autoscuolaRepositionTasks      AutoscuolaAppointmentRepositionTask[]
  autoscuolaMessageTemplates     AutoscuolaMessageTemplate[]
  autoscuolaMessageRules         AutoscuolaMessageRule[]
  autoscuolaMessageLogs          AutoscuolaMessageLog[]
  autoscuolaVoiceLines           AutoscuolaVoiceLine[]
  autoscuolaVoiceCalls           AutoscuolaVoiceCall[]
  autoscuolaVoiceCallbackTasks   AutoscuolaVoiceCallbackTask[]
  autoscuolaVoiceKnowledgeChunks AutoscuolaVoiceKnowledgeChunk[]
  services                       CompanyService[]
  mobileTokens                   MobileAccessToken[]
  pushDevices                    MobilePushDevice[]
}

model CompanyService {
  id         String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId  String               @db.Uuid
  serviceKey ServiceKey
  status     CompanyServiceStatus @default(ACTIVE)
  limits     Json?                @db.Json
  createdAt  DateTime             @default(now()) @db.Timestamp(6)
  updatedAt  DateTime             @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, serviceKey])
  @@index([companyId])
  @@index([serviceKey])
}

model CompanyMember {
  companyId      String         @db.Uuid
  userId         String         @db.Uuid
  role           String         @default("member")
  autoscuolaRole AutoscuolaRole @default(STUDENT)
  createdAt      DateTime       @default(now()) @db.Timestamp(6)
  updatedAt      DateTime       @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([companyId, userId])
  @@index([userId])
}

model CompanyInvite {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId      String   @db.Uuid
  email          String
  role           String   @default("member")
  autoscuolaRole String?
  token          String   @unique
  status         String   @default("pending")
  platform       String?
  expiresAt      DateTime @db.Timestamp(6)
  invitedById    String?  @db.Uuid
  createdAt      DateTime @default(now()) @db.Timestamp(6)
  updatedAt      DateTime @updatedAt

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invitedBy User?   @relation("CompanyInviteInvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([email])
}

model IntegrationConnection {
  id                     String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId              String              @db.Uuid
  provider               IntegrationProvider
  status                 String              @default("connected")
  externalAccountId      String?
  displayName            String?
  scope                  String?
  accessTokenCiphertext  String?
  accessTokenIv          String?
  accessTokenTag         String?
  refreshTokenCiphertext String?
  refreshTokenIv         String?
  refreshTokenTag        String?
  expiresAt              DateTime?
  metadata               Json?
  createdAt              DateTime            @default(now()) @db.Timestamp(6)
  updatedAt              DateTime            @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, provider])
  @@index([provider])
}

model AutoscuolaCase {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId          String    @db.Uuid
  studentId          String    @db.Uuid
  category           String?
  status             String    @default("iscritto")
  theoryExamAt       DateTime? @db.Timestamp(6)
  drivingExamAt      DateTime? @db.Timestamp(6)
  pinkSheetExpiresAt DateTime? @db.Timestamp(6)
  medicalExpiresAt   DateTime? @db.Timestamp(6)
  createdAt          DateTime  @default(now()) @db.Timestamp(6)
  updatedAt          DateTime  @updatedAt

  company      Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  student      User                    @relation(fields: [studentId], references: [id], onDelete: Restrict)
  appointments AutoscuolaAppointment[]
  paymentPlans AutoscuolaPaymentPlan[]

  @@index([companyId])
  @@index([studentId])
  @@index([status])
  @@index([companyId, pinkSheetExpiresAt])
  @@index([companyId, medicalExpiresAt])
}

model AutoscuolaAppointment {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId               String    @db.Uuid
  studentId               String    @db.Uuid
  caseId                  String?   @db.Uuid
  slotId                  String?   @db.Uuid
  type                    String
  startsAt                DateTime  @db.Timestamp(6)
  endsAt                  DateTime? @db.Timestamp(6)
  status                  String    @default("scheduled")
  instructorId            String?   @db.Uuid
  vehicleId               String?   @db.Uuid
  notes                   String?
  paymentRequired         Boolean   @default(false)
  paymentStatus           String    @default("not_required")
  priceAmount             Decimal   @default(0) @db.Decimal(12, 2)
  penaltyAmount           Decimal   @default(0) @db.Decimal(12, 2)
  penaltyCutoffAt         DateTime? @db.Timestamp(6)
  paidAmount              Decimal   @default(0) @db.Decimal(12, 2)
  cancelledAt             DateTime? @db.Timestamp(6)
  cancellationKind        String?
  cancellationReason      String?
  replacedByAppointmentId String?   @db.Uuid
  invoiceId               String?
  invoiceStatus           String?
  creditApplied           Boolean   @default(false)
  creditRefundedAt        DateTime? @db.Timestamp(6)
  createdAt               DateTime  @default(now()) @db.Timestamp(6)
  updatedAt               DateTime  @updatedAt

  company               Company                               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  student               User                                  @relation(fields: [studentId], references: [id], onDelete: Restrict)
  case                  AutoscuolaCase?                       @relation(fields: [caseId], references: [id], onDelete: SetNull)
  slot                  AutoscuolaAvailabilitySlot?           @relation(fields: [slotId], references: [id], onDelete: SetNull)
  instructor            AutoscuolaInstructor?                 @relation(fields: [instructorId], references: [id], onDelete: SetNull)
  vehicle               AutoscuolaVehicle?                    @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  replacedByAppointment AutoscuolaAppointment?                @relation("AutoscuolaAppointmentReplacement", fields: [replacedByAppointmentId], references: [id], onDelete: SetNull)
  replacedAppointments  AutoscuolaAppointment[]               @relation("AutoscuolaAppointmentReplacement")
  payments              AutoscuolaAppointmentPayment[]
  creditLedger          AutoscuolaStudentLessonCreditLedger[]
  messageLogs           AutoscuolaMessageLog[]
  voiceCalls            AutoscuolaVoiceCall[]
  repositionTaskSource  AutoscuolaAppointmentRepositionTask?  @relation("AutoscuolaRepositionSource")
  repositionTaskMatched AutoscuolaAppointmentRepositionTask[] @relation("AutoscuolaRepositionMatched")

  @@index([companyId])
  @@index([studentId])
  @@index([startsAt])
  @@index([instructorId])
  @@index([vehicleId])
  @@index([slotId])
  @@index([paymentRequired, paymentStatus])
  @@index([penaltyCutoffAt])
  @@index([companyId, startsAt])
  @@index([companyId, status, startsAt])
  @@index([companyId, instructorId, startsAt])
  @@index([companyId, studentId, startsAt])
  @@index([companyId, paymentRequired, startsAt])
  @@index([companyId, studentId, creditApplied])
  @@index([replacedByAppointmentId])
  @@index([companyId, cancellationKind, startsAt])
}

model AutoscuolaVoiceLine {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId      String   @db.Uuid
  displayNumber  String
  twilioNumber   String
  twilioPhoneSid String
  status         String   @default("ready")
  routingMode    String   @default("twilio")
  createdAt      DateTime @default(now()) @db.Timestamp(6)
  updatedAt      DateTime @updatedAt

  company Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  calls   AutoscuolaVoiceCall[]

  @@unique([twilioPhoneSid])
  @@index([companyId])
}

model AutoscuolaVoiceCall {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId      String    @db.Uuid
  lineId         String    @db.Uuid
  twilioCallSid  String    @unique
  fromNumber     String
  toNumber       String
  status         String    @default("received")
  studentId      String?   @db.Uuid
  appointmentId  String?   @db.Uuid
  startedAt      DateTime  @default(now()) @db.Timestamp(6)
  endedAt        DateTime? @db.Timestamp(6)
  durationSec    Int?
  outcome        String?
  summary        String?
  recordingSid   String?
  recordingUrl   String?
  transcriptText String?
  needsCallback  Boolean   @default(false)
  createdAt      DateTime  @default(now()) @db.Timestamp(6)
  updatedAt      DateTime  @updatedAt

  company       Company                       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  line          AutoscuolaVoiceLine           @relation(fields: [lineId], references: [id], onDelete: Cascade)
  student       User?                         @relation("AutoscuolaVoiceCallStudent", fields: [studentId], references: [id], onDelete: SetNull)
  appointment   AutoscuolaAppointment?        @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  turns         AutoscuolaVoiceCallTurn[]
  callbackTasks AutoscuolaVoiceCallbackTask[]

  @@index([companyId, status, startedAt])
  @@index([lineId])
  @@index([studentId])
  @@index([appointmentId])
}

model AutoscuolaVoiceCallTurn {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  callId     String   @db.Uuid
  speaker    String
  text       String
  confidence Float?
  createdAt  DateTime @default(now()) @db.Timestamp(6)

  call AutoscuolaVoiceCall @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@index([callId, createdAt])
}

model AutoscuolaVoiceCallbackTask {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId        String    @db.Uuid
  callId           String    @db.Uuid
  studentId        String?   @db.Uuid
  phoneNumber      String
  reason           String
  status           String    @default("pending")
  assignedToUserId String?   @db.Uuid
  nextAttemptAt    DateTime? @db.Timestamp(6)
  attemptCount     Int       @default(0)
  createdAt        DateTime  @default(now()) @db.Timestamp(6)
  updatedAt        DateTime  @updatedAt

  company  Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  call     AutoscuolaVoiceCall @relation(fields: [callId], references: [id], onDelete: Cascade)
  student  User?               @relation("AutoscuolaVoiceCallbackStudent", fields: [studentId], references: [id], onDelete: SetNull)
  assignee User?               @relation("AutoscuolaVoiceCallbackAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)

  @@index([companyId, status, nextAttemptAt])
  @@index([studentId])
}

model AutoscuolaVoiceKnowledgeChunk {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  scope     String
  companyId String?  @db.Uuid
  title     String
  content   String
  tags      String[]
  language  String   @default("it-IT")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt

  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([scope, companyId, language, active])
}

model AutoscuolaAppointmentRepositionTask {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId            String    @db.Uuid
  sourceAppointmentId  String    @db.Uuid
  studentId            String    @db.Uuid
  status               String    @default("pending")
  reason               String
  attemptCount         Int       @default(0)
  nextAttemptAt        DateTime? @db.Timestamp(6)
  lastAttemptAt        DateTime? @db.Timestamp(6)
  matchedAppointmentId String?   @db.Uuid
  createdByUserId      String?   @db.Uuid
  createdAt            DateTime  @default(now()) @db.Timestamp(6)
  updatedAt            DateTime  @updatedAt

  company            Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sourceAppointment  AutoscuolaAppointment  @relation("AutoscuolaRepositionSource", fields: [sourceAppointmentId], references: [id], onDelete: Cascade)
  matchedAppointment AutoscuolaAppointment? @relation("AutoscuolaRepositionMatched", fields: [matchedAppointmentId], references: [id], onDelete: SetNull)
  student            User                   @relation("AutoscuolaRepositionTaskStudent", fields: [studentId], references: [id], onDelete: Restrict)
  createdByUser      User?                  @relation("AutoscuolaRepositionTaskActor", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([sourceAppointmentId])
  @@index([companyId, status, nextAttemptAt])
  @@index([studentId, status])
}

model AutoscuolaInstructor {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String   @db.Uuid
  userId    String?  @db.Uuid
  name      String
  phone     String?
  status    String   @default("active")
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt

  company      Company                      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user         User?                        @relation(fields: [userId], references: [id], onDelete: SetNull)
  appointments AutoscuolaAppointment[]
  blocks       AutoscuolaInstructorBlock[]

  @@unique([companyId, userId])
  @@index([companyId])
  @@index([userId])
}

model AutoscuolaInstructorBlock {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId    String   @db.Uuid
  instructorId String   @db.Uuid
  startsAt     DateTime @db.Timestamp(6)
  endsAt       DateTime @db.Timestamp(6)
  reason       String?
  createdAt    DateTime @default(now()) @db.Timestamp(6)
  updatedAt    DateTime @updatedAt

  company    Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  instructor AutoscuolaInstructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@index([companyId, instructorId, startsAt])
  @@index([instructorId, startsAt])
}

model AutoscuolaVehicle {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String   @db.Uuid
  name      String
  plate     String?
  status    String   @default("active")
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt

  company      Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  appointments AutoscuolaAppointment[]

  @@index([companyId])
}

model AutoscuolaWeeklyAvailability {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId     String   @db.Uuid
  ownerType     String
  ownerId       String   @db.Uuid
  daysOfWeek    Int[]
  ranges        Json?    @db.Json
  startMinutes  Int
  endMinutes    Int
  startMinutes2 Int?
  endMinutes2   Int?
  createdAt     DateTime @default(now()) @db.Timestamp(6)
  updatedAt     DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, ownerType, ownerId])
  @@index([companyId])
  @@index([ownerType, ownerId])
}

model AutoscuolaDailyAvailabilityOverride {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String   @db.Uuid
  ownerType String
  ownerId   String   @db.Uuid
  date      DateTime @db.Date
  ranges    Json     @db.Json
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, ownerType, ownerId, date], map: "AutoscuolaDailyAvailabilityOverride_company_owner_date_key")
  @@index([companyId, ownerType, ownerId], map: "AutoscuolaDailyAvailabilityOverride_company_owner_idx")
  @@index([ownerId, date])
}

model AutoscuolaAvailabilitySlot {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String   @db.Uuid
  ownerType String
  ownerId   String   @db.Uuid
  startsAt  DateTime @db.Timestamp(6)
  endsAt    DateTime @db.Timestamp(6)
  status    String   @default("open")
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt

  company        Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  appointments   AutoscuolaAppointment[]
  waitlistOffers AutoscuolaWaitlistOffer[]

  @@unique([companyId, ownerType, ownerId, startsAt])
  @@index([companyId])
  @@index([ownerType, ownerId])
  @@index([startsAt])
}

model AutoscuolaBookingRequest {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String   @db.Uuid
  studentId   String   @db.Uuid
  desiredDate DateTime @db.Timestamp(6)
  status      String   @default("pending")
  createdAt   DateTime @default(now()) @db.Timestamp(6)
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  student User    @relation(fields: [studentId], references: [id], onDelete: Restrict)

  @@index([companyId])
  @@index([studentId])
  @@index([desiredDate])
}

model AutoscuolaWaitlistOffer {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String   @db.Uuid
  slotId    String   @db.Uuid
  status    String   @default("broadcasted")
  sentAt    DateTime @db.Timestamp(6)
  expiresAt DateTime @db.Timestamp(6)
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt

  company   Company                      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  slot      AutoscuolaAvailabilitySlot   @relation(fields: [slotId], references: [id], onDelete: Cascade)
  responses AutoscuolaWaitlistResponse[]

  @@index([companyId])
  @@index([slotId])
}

model AutoscuolaWaitlistResponse {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  offerId     String   @db.Uuid
  studentId   String   @db.Uuid
  status      String   @default("accepted")
  respondedAt DateTime @db.Timestamp(6)
  createdAt   DateTime @default(now()) @db.Timestamp(6)
  updatedAt   DateTime @updatedAt

  offer   AutoscuolaWaitlistOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  student User                    @relation(fields: [studentId], references: [id], onDelete: Restrict)

  @@index([offerId])
  @@index([studentId])
}

model AutoscuolaDocument {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String    @db.Uuid
  studentId String    @db.Uuid
  name      String
  status    String    @default("missing")
  fileUrl   String?
  expiresAt DateTime? @db.Timestamp(6)
  createdAt DateTime  @default(now()) @db.Timestamp(6)
  updatedAt DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  student User    @relation(fields: [studentId], references: [id], onDelete: Restrict)

  @@index([companyId])
  @@index([studentId])
}

model AutoscuolaPaymentPlan {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String   @db.Uuid
  studentId   String   @db.Uuid
  caseId      String?  @db.Uuid
  totalAmount Decimal  @db.Decimal(12, 2)
  currency    String   @default("EUR")
  status      String   @default("active")
  createdAt   DateTime @default(now()) @db.Timestamp(6)
  updatedAt   DateTime @updatedAt

  company      Company                        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  student      User                           @relation(fields: [studentId], references: [id], onDelete: Restrict)
  case         AutoscuolaCase?                @relation(fields: [caseId], references: [id], onDelete: SetNull)
  installments AutoscuolaPaymentInstallment[]

  @@index([companyId])
  @@index([studentId])
}

model AutoscuolaPaymentInstallment {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  planId    String    @db.Uuid
  dueDate   DateTime  @db.Timestamp(6)
  amount    Decimal   @db.Decimal(12, 2)
  status    String    @default("pending")
  paidAt    DateTime? @db.Timestamp(6)
  invoiceId String?
  createdAt DateTime  @default(now()) @db.Timestamp(6)
  updatedAt DateTime  @updatedAt

  plan AutoscuolaPaymentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@index([dueDate])
  @@index([planId, status, dueDate])
  @@index([status, dueDate])
}

model AutoscuolaStudentPaymentProfile {
  id                           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId                    String   @db.Uuid
  studentId                    String   @db.Uuid
  stripeCustomerId             String
  stripeDefaultPaymentMethodId String?
  ficClientId                  String?
  status                       String   @default("active")
  createdAt                    DateTime @default(now()) @db.Timestamp(6)
  updatedAt                    DateTime @updatedAt

  company  Company                        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  student  User                           @relation(fields: [studentId], references: [id], onDelete: Restrict)
  payments AutoscuolaAppointmentPayment[]

  @@unique([companyId, studentId])
  @@index([companyId])
  @@index([studentId])
}

model AutoscuolaStudentLessonCreditBalance {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId        String   @db.Uuid
  studentId        String   @db.Uuid
  availableCredits Int      @default(0)
  createdAt        DateTime @default(now()) @db.Timestamp(6)
  updatedAt        DateTime @updatedAt

  company Company                               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  student User                                  @relation(fields: [studentId], references: [id], onDelete: Restrict)
  ledger  AutoscuolaStudentLessonCreditLedger[]

  @@unique([companyId, studentId])
  @@index([companyId])
  @@index([studentId])
}

model AutoscuolaStudentLessonCreditLedger {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId     String   @db.Uuid
  studentId     String   @db.Uuid
  balanceId     String   @db.Uuid
  appointmentId String?  @db.Uuid
  delta         Int
  reason        String
  actorUserId   String?  @db.Uuid
  createdAt     DateTime @default(now()) @db.Timestamp(6)

  company     Company                              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  student     User                                 @relation("AutoscuolaCreditLedgerStudent", fields: [studentId], references: [id], onDelete: Restrict)
  balance     AutoscuolaStudentLessonCreditBalance @relation(fields: [balanceId], references: [id], onDelete: Cascade)
  appointment AutoscuolaAppointment?               @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  actor       User?                                @relation("AutoscuolaCreditLedgerActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([companyId, studentId, createdAt])
  @@index([appointmentId])
}

model AutoscuolaAppointmentPayment {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  appointmentId         String    @db.Uuid
  companyId             String    @db.Uuid
  studentId             String    @db.Uuid
  profileId             String?   @db.Uuid
  phase                 String
  amount                Decimal   @db.Decimal(12, 2)
  currency              String    @default("EUR")
  status                String    @default("pending")
  attemptCount          Int       @default(0)
  nextAttemptAt         DateTime? @db.Timestamp(6)
  stripePaymentIntentId String?
  stripeChargeId        String?
  failureCode           String?
  failureMessage        String?
  paidAt                DateTime? @db.Timestamp(6)
  createdAt             DateTime  @default(now()) @db.Timestamp(6)
  updatedAt             DateTime  @updatedAt

  appointment AutoscuolaAppointment            @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  company     Company                          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  student     User                             @relation(fields: [studentId], references: [id], onDelete: Restrict)
  profile     AutoscuolaStudentPaymentProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)

  @@unique([stripePaymentIntentId])
  @@index([appointmentId])
  @@index([companyId, studentId])
  @@index([status, nextAttemptAt])
  @@index([phase])
  @@index([companyId, appointmentId, createdAt])
  @@index([appointmentId, status])
}

model AutoscuolaMessageTemplate {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String   @db.Uuid
  name      String
  channel   String
  subject   String?
  body      String
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt

  company Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  rules   AutoscuolaMessageRule[]
  logs    AutoscuolaMessageLog[]

  @@index([companyId])
}

model AutoscuolaMessageRule {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId       String   @db.Uuid
  templateId      String   @db.Uuid
  type            String // APPOINTMENT_BEFORE, CASE_STATUS_CHANGED
  appointmentType String? // guida, esame
  deadlineType    String? // PINK_SHEET_EXPIRES, MEDICAL_EXPIRES
  offsetDays      Int      @default(0)
  channel         String // email, sms
  target          String // student, staff
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @db.Timestamp(6)
  updatedAt       DateTime @updatedAt

  company  Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  template AutoscuolaMessageTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  logs     AutoscuolaMessageLog[]

  @@index([companyId])
  @@index([type])
}

model AutoscuolaMessageLog {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId     String   @db.Uuid
  ruleId        String   @db.Uuid
  templateId    String   @db.Uuid
  appointmentId String?  @db.Uuid
  studentId     String?  @db.Uuid
  channel       String
  recipient     String
  status        String   @default("sent")
  error         String?
  payload       Json?
  sentAt        DateTime @default(now()) @db.Timestamp(6)

  company     Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  rule        AutoscuolaMessageRule     @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  template    AutoscuolaMessageTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  appointment AutoscuolaAppointment?    @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  student     User?                     @relation(fields: [studentId], references: [id], onDelete: SetNull)

  @@unique([ruleId, appointmentId, recipient, channel])
  @@index([companyId])
  @@index([ruleId])
  @@index([appointmentId])
}
